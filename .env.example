# DigiPeople Core 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ======================
# 后端服务配置
# ======================

# 后端服务监听地址和端口
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 是否启用调试模式
DEBUG=true

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ======================
# Fay 服务配置
# ======================

# Fay 服务地址（如果运行在容器内，使用容器名；如果运行在主机，使用 host.docker.internal 或 127.0.0.1）
FAY_HOST=127.0.0.1
FAY_PORT=10002

# Fay WebSocket 完整 URL
FAY_WS_URL=ws://127.0.0.1:10002

# Fay 管理界面端口（可选）
FAY_ADMIN_PORT=5000

# Fay MCP 服务端口（可选）
FAY_MCP_PORT=5010

# ======================
# MuseTalk 配置
# ======================

# MuseTalk 项目路径（相对于项目根目录）
MUSETALK_PATH=./MuseTalk

# MuseTalk 模型版本 (v15 或 v1，推荐 v15)
MUSETALK_MODEL_VERSION=v15

# 是否使用 float16 模式（减少显存使用，可能影响质量）
MUSETALK_USE_FLOAT16=true

# MuseTalk 推理参数
MUSETALK_BBOX_SHIFT=0
MUSETALK_FPS=25

# FFmpeg 路径（如果不在系统 PATH 中）
# FFMPEG_PATH=/usr/bin/ffmpeg

# MuseTalk Python 解释器路径（应指向 MuseTalk 的虚拟环境）
# 例如：./MuseTalk/venv/Scripts/python.exe（Windows）或 ./MuseTalk/venv/bin/python（Linux）
# 留空则自动检测 MuseTalk/venv 下的 python
# MUSETALK_PYTHON_PATH=

# ======================
# 路径配置
# ======================

# 数据根目录
DATA_DIR=./data

# 数字人形象存储目录
AVATAR_DIR=./data/avatars

# 音频文件存储目录
AUDIO_DIR=./data/audio

# 视频文件存储目录
VIDEO_DIR=./data/videos

# 上传文件存储目录
UPLOAD_DIR=./data/uploads

# 临时文件目录
TEMP_DIR=./data/temp

# ======================
# 任务队列配置（可选）
# ======================

# Redis 连接（用于任务队列，如果启用）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ======================
# 数据库配置（可选）
# ======================

# PostgreSQL 连接
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=digipeople
# DB_USER=digipeople
# DB_PASSWORD=digipeople_pass

# ======================
# 安全配置
# ======================

# API 密钥（用于保护接口）
# API_KEY=your_api_key_here

# CORS 允许的源
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ======================
# 性能配置
# ======================

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE=100

# 并发任务数
MAX_CONCURRENT_TASKS=2

# 视频生成超时时间（秒）
VIDEO_GENERATION_TIMEOUT=300

# ======================
# 开发配置
# ======================

# 是否启用热重载（开发环境）
RELOAD=true

# 是否启用详细日志
VERBOSE_LOGGING=false

# ======================
# GPU 配置（Linux 专用）
# ======================

# NVIDIA 容器运行时（如果使用 GPU）
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility

# ======================
# 外部服务配置（可选）
# ======================

# OpenAI API 配置（如果使用 OpenAI 模型）
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 其他 LLM 服务配置
# LLM_API_KEY=your_llm_api_key
# LLM_BASE_URL=https://api.example.com/v1

# Ollama 配置（占位符，实际通过 Fay 集成）
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# vLLM 配置（占位符，实际通过 Fay 集成）
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# TTS 服务配置
# TTS_SERVICE=ali  # ali, gptsovits, gptsovits_v3, volcano, ms
# TTS_API_KEY=your_tts_api_key
# TTS_REGION=your_region